                  (wbuf-byte! sec CT-INSTANCE) (wbuf-u32! sec 4)
                  (wbuf-byte! sec IDECL-ALIAS) (wbuf-byte! sec CEXT-TYPE)
                  (wbuf-byte! sec ALIAS-OUTER) (wbuf-u32! sec 1) (wbuf-u32! sec ty-output-stream)
