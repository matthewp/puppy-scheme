                    (wbuf-byte! sec IDECL-TYPE) (wbuf-byte! sec CVT-OWN) (wbuf-u32! sec 0)
                    ;; local 2: tuple<own<desc>(1), string>
                    (wbuf-byte! sec IDECL-TYPE)
                    (wbuf-byte! sec CVT-TUPLE) (wbuf-u32! sec 2)
                    (wbuf-u32! sec 1) (wbuf-byte! sec CVT-STRING)
