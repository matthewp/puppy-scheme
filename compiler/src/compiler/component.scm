      ;; wasi:clocks/monotonic-clock
      (when needs-clock
        (let ((ty-clock-inst next-type))
          (set! next-type (+ next-type 1))
          (wbuf-reset! sec)
          (wbuf-u32! sec 1)
          ;; instance type with 4 declarations (all types defined inside)
          (wbuf-byte! sec CT-INSTANCE) (wbuf-u32! sec 4)
