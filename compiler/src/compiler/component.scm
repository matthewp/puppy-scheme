                    (wbuf-reset! sec) (wbuf-u32! sec 1)
                    (wbuf-byte! sec #x00) (wbuf-name! sec "wasi:filesystem/types@0.2.0")
                    (wbuf-byte! sec CEXT-INSTANCE) (wbuf-u32! sec ty-fs-inst)
